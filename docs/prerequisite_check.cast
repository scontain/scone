[4.563648, "o", "\r\n"]
[4.584548, "o", "  \u001b[0m\u001b[1mstable-x86_64-unknown-linux-gnu unchanged\u001b[0m - rustc 1.93.1 (01f6ddf75 2026-02-11)\r\n\r\n\u001b[0m\u001b[1minfo: \u001b[0mself-update is disabled for this build of rustup\r\n\u001b[0m\u001b[1minfo: \u001b[0many updates to rustup will need to be fetched with your system package manager\r\n"]
