[3.800709, "o", "cargo 1.93.1 (083ac5135 2025-12-15)\r\n"]
[3.9816, "o", "Installing toolchain: stable\r\n"]
[4.184503, "o", "\u001b[0m\u001b[1minfo: \u001b[0msyncing channel updates for 'stable-x86_64-unknown-linux-gnu'\r\n"]
[4.497722, "o", "\r\n"]
[4.510894, "o", "  \u001b[0m\u001b[1mstable-x86_64-unknown-linux-gnu unchanged\u001b[0m - rustc 1.93.1 (01f6ddf75 2026-02-11)\r\n\r\n\u001b[0m\u001b[1minfo: \u001b[0mself-update is disabled for this build of rustup\r\n\u001b[0m\u001b[1minfo: \u001b[0many updates to rustup will need to be fetched with your system package manager\r\n"]
[4.664772, "o", "\u001b[0m\u001b[1minfo: \u001b[0musing existing install for 'stable-x86_64-unknown-linux-gnu'\r\n"]
[4.707219, "o", "\u001b[0m\u001b[1minfo: \u001b[0mdefault toolchain set to 'stable-x86_64-unknown-linux-gnu'\r\n"]
